{
	"name": "neosanitize",
	"version": "0.3.0",
	"description": "Zero-dependency, isomorphic HTML sanitizer: a fast browser-faithful WHATWG engine (deny-by-default) plus a drop-in sanitize-html-compatible legacy engine.",
	"author": "Puru Vijay <devpuruvj@gmail.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PuruVJ/neosanitize.git",
		"directory": "packages/neosanitize"
	},
	"homepage": "https://github.com/PuruVJ/neosanitize#readme",
	"bugs": "https://github.com/PuruVJ/neosanitize/issues",
	"keywords": [
		"html",
		"parser",
		"sanitizer",
		"sanitize",
		"xss",
		"typescript",
		"zero-dependency"
	],
	"type": "module",
	"main": "./dist/main/index.mjs",
	"module": "./dist/main/index.mjs",
	"types": "./dist/main/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/main/index.d.mts",
			"browser": "./dist/main/browser.mjs",
			"import": "./dist/main/index.mjs",
			"default": "./dist/main/index.mjs"
		},
		"./browser": {
			"types": "./dist/main/browser.d.mts",
			"default": "./dist/main/browser.mjs"
		},
		"./legacy": {
			"require": {
				"types": "./dist/legacy/index.d.cts",
				"default": "./dist/legacy/index.cjs"
			},
			"import": {
				"types": "./dist/legacy/index.d.mts",
				"default": "./dist/legacy/index.mjs"
			},
			"default": "./dist/legacy/index.cjs"
		},
		"./presets": {
			"types": "./dist/main/presets/index.d.mts",
			"import": "./dist/main/presets/index.mjs"
		},
		"./whatwg-parser": {
			"types": "./dist/main/whatwg-parser/index.d.mts",
			"import": "./dist/main/whatwg-parser/index.mjs"
		},
		"./parse5": {
			"types": "./dist/main/parse5.d.mts",
			"import": "./dist/main/parse5.mjs"
		},
		"./htmlparser2": {
			"types": "./dist/main/htmlparser2.d.mts",
			"import": "./dist/main/htmlparser2.mjs"
		}
	},
	"peerDependencies": {
		"parse5": ">=7",
		"htmlparser2": ">=9"
	},
	"peerDependenciesMeta": {
		"parse5": {
			"optional": true
		},
		"htmlparser2": {
			"optional": true
		}
	},
	"sideEffects": false,
	"files": [
		"dist",
		"legacy.*"
	],
	"scripts": {
		"build": "rm -rf dist && tsdown && node scripts/legacy-stubs.mjs",
		"dev": "tsdown --watch",
		"test": "pnpm build && vitest run",
		"test:watch": "vitest",
		"bench": "pnpm build && node bench/index.mjs",
		"bench:3way": "pnpm build && node bench/three-way.mjs",
		"bench:adapters": "pnpm build && node bench/adapters.mjs --json",
		"fuzz": "pnpm build && node audit/fuzz.mjs",
		"fuzz:loop": "pnpm build && node audit/fuzz-loop.mjs",
		"coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "pnpm build"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"@types/sanitize-html": "^2.16.1",
		"@vitest/coverage-v8": "^4",
		"happy-dom": "^20.10.6",
		"htmlparser2": "^12.0.0",
		"parse5": "^8.0.1",
		"sanitize-html": "^2.17.5",
		"sinon": "^22.0.0",
		"tinybench": "^6.0.2",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"vite": "^6",
		"vitest": "^4.1.7"
	}
}
